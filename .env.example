
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_NAME=ocr-extraction
APP_VERSION=1.0.0

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=invoice_processing_db
DB_SCHEMA=public
DB_SSL=false
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_POOL_SIZE=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
REDIS_KEY_PREFIX=invoice-processing:

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=invoice-processing-api
KAFKA_GROUP_ID=invoice-processing-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

STORAGE_TYPE=local

MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=invoice-processing-bucket
MINIO_ENDPOINT=

LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_BASE_URL=http://localhost:3000/uploads


VEDAS_OCR_API_URL=https://pos-ocr.vedastudios.com.np/api/v1/extract
OCR_KAFKA_TOPIC=ocr.processing
OCR_JOB_CACHE_TTL=86400

LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
